# Copy this file to .env for local runs. GitHub Actions uses repo secrets/vars instead.

# Instagram Graph API (from Meta Developer app)
IG_ACCESS_TOKEN=your_long_lived_token_here
IG_BUSINESS_ACCOUNT_ID=1784xxxxxxxxxxxxxx

# Google Gemini (free tier)
GEMINI_API_KEY=your_gemini_key_here

# Branding (shown on every image)
BRAND_NAME=FinanceBlueprint
BRAND_HANDLE=@financeblueprint

# GitHub repo info — only needed when running locally with the publisher
GITHUB_REPO=yourname/finance-ig-bot
GITHUB_REF_NAME=main
